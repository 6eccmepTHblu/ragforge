# Copy to `.env` and adjust. Every variable is optional — the defaults run the
# whole service offline (mock LLM + hash embeddings + in-memory store).

# --- General ---
RAGFORGE_ENVIRONMENT=dev
RAGFORGE_DATA_DIR=./.ragforge_data

# --- LLM: mock | openai | anthropic ---
RAGFORGE_LLM_PROVIDER=mock
# RAGFORGE_OPENAI_API_KEY=sk-...
# RAGFORGE_OPENAI_MODEL=gpt-4o-mini
# RAGFORGE_ANTHROPIC_API_KEY=sk-ant-...
# RAGFORGE_ANTHROPIC_MODEL=claude-sonnet-5

# --- Embeddings: hash | openai ---
RAGFORGE_EMBEDDING_PROVIDER=hash
# RAGFORGE_OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Vector store: memory | chroma ---
RAGFORGE_VECTORSTORE=memory
RAGFORGE_PERSIST_VECTORSTORE=true

# --- Chunking (tokens) ---
RAGFORGE_CHUNK_SIZE=512
RAGFORGE_CHUNK_OVERLAP=64

# --- Retrieval ---
RAGFORGE_TOP_K=4
RAGFORGE_USE_HYBRID=true
